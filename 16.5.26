show databases;
create database VITCampus;
use VITCampus;
create table CSE(
sid int8,
sname varchar(50),
smarks int1
);
create table MEE(
sid int8,
sname varchar(50),
smarks int1
);
create table Mech(
sid int8,
sname varchar(50),
smarks int1
);

show tables from VITCampus;
select * from cse;
