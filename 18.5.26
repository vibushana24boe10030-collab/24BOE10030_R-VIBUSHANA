START TRANSACTION;

UPDATE Students
SET sname = 'Abhijit'
WHERE sid = 5;

SAVEPOINT A;

INSERT INTO Students
VALUES (6, 'Chris', 'CSE');

SAVEPOINT B;

INSERT INTO Students
VALUES (7, 'Bravo', 'ECE');

SAVEPOINT C;

SELECT * FROM Students;

COMMIT;


SET SQL_SAFE_UPDATES = 0;

UPDATE Students
SET sname = 'Abhijit'
WHERE sid = 5;

SELECT * FROM Students;



START TRANSACTION;

