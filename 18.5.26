ALTER TABLE Students
DROP COLUMN branch;

ALTER TABLE Students
ADD (
    country VARCHAR(30) DEFAULT 'INDIA'
);

ALTER TABLE Students
RENAME COLUMN country TO location;



ALTER TABLE Faculty
DROP COLUMN subject;

ALTER TABLE Faculty
ADD (
    experience INT DEFAULT 5
);

ALTER TABLE Faculty
RENAME COLUMN experience TO years_of_experience;



ALTER TABLE Marks
DROP COLUMN subject;

ALTER TABLE Marks
ADD (
    grade VARCHAR(5) DEFAULT 'A'
);

ALTER TABLE Marks
RENAME COLUMN grade TO final_grade;



